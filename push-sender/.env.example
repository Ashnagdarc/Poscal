# PosCal Push Notification Sender - Environment Variables

# ===================================
# NestJS Backend Configuration (REQUIRED)
# ===================================
# Base URL for NestJS API (Nest defaults to 3001 unless PORT overrides it)
NESTJS_API_URL=http://localhost:3001

# Service token for internal authentication (must match backend SERVICE_TOKEN)
NESTJS_SERVICE_TOKEN=poscal_service_2026_secure_token_change_in_production

# ===================================
# Market Data API Configuration (REQUIRED)
# ===================================
# Price ingestor live runtime now uses the shared Finnhub stream path only.
# PRICE_PROVIDER_MODE is kept for backward compatibility but ignored unless set to "finnhub".
PRICE_PROVIDER_MODE=finnhub

# Finnhub WebSocket API (FREE, unlimited real-time updates)
# Required for the live ingestor runtime
# Get your free API key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Curated production symbols pushed into the shared backend cache.
# Keep this aligned with VITE_LIVE_SYMBOLS unless you intentionally want fewer live pairs.
LIVE_SYMBOLS=EUR/USD,GBP/USD,USD/JPY,USD/CHF,AUD/USD,USD/CAD,NZD/USD,EUR/GBP,EUR/JPY,GBP/JPY,AUD/JPY,EUR/CHF,GBP/CHF,XAU/USD,XAG/USD,BTC/USD,ETH/USD

# ===================================
# VAPID Keys for Web Push (REQUIRED)
# ===================================
# These are already in your frontend code at:
# src/hooks/use-push-notifications.ts
# Required only when running the notification worker

# Public key (line 7 in use-push-notifications.ts)
VAPID_PUBLIC_KEY=BE7EfMew8pPJTxly2cBT7PxInN62M2HWPB0yB-bNGwUniu0b2ouoLbEmfiQjHu5vowBcW0caNzaWpwP9mBZ0CM0

# Private key (you need to find this - was used when generating VAPID keys)
# If you don't have it, you'll need to generate new VAPID keys
VAPID_PRIVATE_KEY=PaCGXpLpjIRr8CMRs5YrvJPkUOTw05Ngq6gcMmFBowI

# Contact email for push service (OPTIONAL, defaults to mailto:admin@poscal.app)
VAPID_SUBJECT=mailto:info@poscalfx.com

# ===================================
# Logging (OPTIONAL)
# ===================================
# Set to "true" to include verbose worker logs
DEBUG_LOGS=false

# ===================================
# Service Configuration (OPTIONAL)
# ===================================
# How often the notification worker polls `/notifications/push/pending` (milliseconds)
# Default: 30000 (30 seconds)
# Increase for less frequent checks, decrease for faster delivery
POLL_INTERVAL=30000

# How often the price ingestor flushes the shared cache to `/prices/batch-update` (milliseconds)
# Default: 20000 (20 seconds)
BATCH_INTERVAL=20000
