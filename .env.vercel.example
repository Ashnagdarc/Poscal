# Server-side environment variables for Vercel `api/` functions only.
# Do not copy these into `.env.production` because that file is exposed to the frontend build.
# In production, set them in the Vercel dashboard. For local `vercel dev`, place the needed values
# in a local `.env` or `.env.local`.

# Convex deployment URL for Vercel serverless functions.
CONVEX_URL=https://your-convex-deployment.convex.cloud

# Required by /api/paystack-webhook signature verification.
PAYSTACK_WEBHOOK_SECRET=whsec_change_me
# Shared secret used by Vercel serverless functions to sync payment/subscription state into Convex.
PAYMENT_SYNC_SECRET=change_me

# Optional: if you still use the Convex HTTP ingest/process endpoints from external workers.
PRICE_INGEST_SECRET=change_me
NOTIFICATION_WORKER_SECRET=change_me

# Resend configuration for scheduled reminder emails.
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Poscal <noreply@poscalfx.com>

# Web Push delivery
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:info@poscalfx.com
