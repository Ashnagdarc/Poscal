# Server-side environment variables for Vercel `api/` functions only.
# Do not copy these into `.env.production` because that file is exposed to the frontend build.
# In production, set them in the Vercel dashboard. For local `vercel dev`, place the needed values
# in a local `.env` or `.env.local`.

# IMPORTANT:
# Supabase keys still appear here because some existing serverless handlers write directly to Supabase:
# - /api/paystack-webhook
# - /api/restore-purchase
# - /api/scheduled-expiry
# - /api/scheduled-reminder
# If you later migrate those handlers fully to backend APIs, you can remove SUPABASE_*.

# Required by /api/verify-payment (and other backend-proxy handlers)
# Backend proxy target for serverless handlers that forward requests to NestJS.
BACKEND_URL=https://api.poscalfx.com

# Shared service token for privileged backend-to-backend calls.
BACKEND_SERVICE_TOKEN=change_me

# Required by /api/paystack-webhook signature verification.
PAYSTACK_WEBHOOK_SECRET=whsec_change_me

# Required by legacy Supabase-writing handlers listed above.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend configuration for scheduled reminder emails.
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Poscal <noreply@poscalfx.com>
