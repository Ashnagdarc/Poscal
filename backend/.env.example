# Environment Configuration for Poscal Backend

# Node Environment
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=poscal_user
DB_PASSWORD=postgres
DB_NAME=poscal_db
DB_SSL=false
# For Docker-first local boot on an empty database, the container can
# bootstrap tables from entities once before running migrations.
DB_AUTO_BOOTSTRAP=false

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# Internal service tokens
# SERVICE_TOKEN is used by push-sender when calling protected backend endpoints.
SERVICE_TOKEN=poscal_service_2026_secure_token_change_in_production

# BACKEND_SERVICE_TOKEN is used by the Vercel payment verification endpoint.
# You can keep this equal to SERVICE_TOKEN if you want a single internal token.
BACKEND_SERVICE_TOKEN=poscal_service_2026_secure_token_change_in_production

# Frontend URLs (for CORS)
FRONTEND_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://poscal.com

# Finnhub API (for real-time prices)
FINNHUB_API_KEY=your-finnhub-api-key

# Email Configuration (optional)
SMTP_HOST=smtp.sendbaba.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
MAIL_FROM=Poscal <noreply@poscalfx.com>

# Web Push Configuration (for push notifications)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Features
ENABLE_REALTIME_PRICES=true
ENABLE_PUSH_NOTIFICATIONS=true
